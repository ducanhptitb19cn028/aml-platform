<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!--
      Structured JSON logs for Loki / Elasticsearch. Each line carries:
        - traceId, spanId  (joins log-features to trace-features in your model)
        - service, env     (cardinality keys for multi-service experiments)
        - business fields  (case.id, customer.id, risk.band) via MDC
    -->
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <includeMdc>true</includeMdc>
            <customFields>{"service":"case-management"}</customFields>
            <fieldNames>
                <timestamp>@timestamp</timestamp>
                <message>message</message>
                <thread>thread</thread>
                <logger>logger</logger>
                <level>level</level>
            </fieldNames>
        </encoder>
    </appender>

    <root level="INFO">
        <appender-ref ref="STDOUT"/>
    </root>
</configuration>

    {
      "name": "ML Engine",
      "item": [
        {
          "name": "Score Incidents – single feature record",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{ml_url}}/v1/incidents/score",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"features\": [\n    {\n      \"windowId\": \"win-001\",\n      \"service\": \"transaction-monitoring\",\n      \"windowStart\": \"2026-05-12T02:00:00Z\",\n      \"windowEnd\":   \"2026-05-12T02:05:00Z\",\n      \"avgValue\": 620.5,\n      \"maxValue\": 980.0,\n      \"rateOfChange\": 1.45,\n      \"metricName\": \"http_request_duration_ms_p95\",\n      \"sampleCount\": 300\n    }\n  ]\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('200 OK', () => pm.response.to.have.status(200));",
              "const list = pm.response.json();",
              "pm.test('array response', () => pm.expect(list).to.be.an('array'));",
              "pm.test('one result', () => pm.expect(list.length).to.equal(1));",
              "const inc = list[0];",
              "pm.test('incidentId present', () => pm.expect(inc.incidentId).to.be.a('string').and.not.empty);",
              "pm.test('anomalyScore in [0,1]', () => pm.expect(inc.anomalyScore).to.be.within(0, 1));",
              "pm.test('affectedServices array', () => pm.expect(inc.affectedServices).to.be.an('array'));",
              "pm.test('rootCauseRanking array', () => pm.expect(inc.rootCauseRanking).to.be.an('array'));",
              "pm.test('breachEtaMinutes int', () => pm.expect(inc.breachEtaMinutes).to.be.a('number'));",
              "pm.collectionVariables.set('incidentId', inc.incidentId);"
            ], "type": "text/javascript" }
          }]
        },
        {
          "name": "Score Incidents – batch (3 services)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{ml_url}}/v1/incidents/score",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"features\": [\n    {\n      \"windowId\": \"win-002\",\n      \"service\": \"customer-kyc\",\n      \"windowStart\": \"2026-05-12T02:00:00Z\",\n      \"windowEnd\":   \"2026-05-12T02:05:00Z\",\n      \"avgValue\": 55.0,\n      \"maxValue\": 120.0,\n      \"rateOfChange\": 0.1,\n      \"metricName\": \"http_request_duration_ms_p95\",\n      \"sampleCount\": 150\n    },\n    {\n      \"windowId\": \"win-003\",\n      \"service\": \"transaction-monitoring\",\n      \"windowStart\": \"2026-05-12T02:00:00Z\",\n      \"windowEnd\":   \"2026-05-12T02:05:00Z\",\n      \"avgValue\": 850.0,\n      \"maxValue\": 1500.0,\n      \"rateOfChange\": 3.2,\n      \"metricName\": \"http_request_duration_ms_p95\",\n      \"sampleCount\": 300\n    },\n    {\n      \"windowId\": \"win-004\",\n      \"service\": \"case-management\",\n      \"windowStart\": \"2026-05-12T02:00:00Z\",\n      \"windowEnd\":   \"2026-05-12T02:05:00Z\",\n      \"avgValue\": 200.0,\n      \"maxValue\": 350.0,\n      \"rateOfChange\": 0.5,\n      \"metricName\": \"http_request_duration_ms_p95\",\n      \"sampleCount\": 200\n    }\n  ]\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('200 OK', () => pm.response.to.have.status(200));",
              "const list = pm.response.json();",
              "pm.test('3 results', () => pm.expect(list.length).to.equal(3));",
              "list.forEach((inc, i) => {",
              "  pm.test(`[${i}] anomalyScore in [0,1]`, () => pm.expect(inc.anomalyScore).to.be.within(0, 1));",
              "  pm.test(`[${i}] confidence in [0,1]`, () => pm.expect(inc.confidence).to.be.within(0, 1));",
              "});"
            ], "type": "text/javascript" }
          }]

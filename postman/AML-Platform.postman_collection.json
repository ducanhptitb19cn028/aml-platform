    {
      "name": "End-to-End Flow",
      "description": "Run this folder in order: seeds a full lifecycle from KYC onboarding through transaction alert to case management to AIOps analysis.",
      "item": [
        {
          "name": "E2E 1 – Onboard Customer",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{kyc_url}}/api/v1/customers",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerId\": \"CUST-E2E-001\",\n  \"legalName\": \"Dragon Shell Corp\",\n  \"residencyCountry\": \"CN\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('201 Created', () => pm.response.to.have.status(201));",
              "pm.collectionVariables.set('customerId', pm.response.json().id);"
            ], "type": "text/javascript" }
          }]
        },
        {
          "name": "E2E 2 – Verify Customer",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{kyc_url}}/api/v1/customers/{{customerId}}/verify",
            "body": {
              "mode": "raw",
              "raw": "{ \"verifiedBy\": \"kyc-officer-01\" }"
            }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('204 No Content', () => pm.response.to.have.status(204));"
            ], "type": "text/javascript" }
          }]
        },
        {
          "name": "E2E 3 – Evaluate High-Risk Transaction",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{txn_url}}/api/v1/transactions/evaluate",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerId\": \"{{customerId}}\",\n  \"amount\": \"120000.00\",\n  \"currency\": \"USD\",\n  \"originCountry\": \"CN\",\n  \"destinationCountry\": \"KP\",\n  \"channel\": \"SWIFT\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('200 or 201', () => pm.expect(pm.response.code).to.be.oneOf([200, 201]));",
              "const b = pm.response.json();",
              "if (b.alertId) pm.collectionVariables.set('alertId', b.alertId);",
              "else pm.collectionVariables.set('alertId', 'ALERT-E2E-FALLBACK');"
            ], "type": "text/javascript" }
          }]
        },
        {
          "name": "E2E 4 – Open Case",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{case_url}}/api/v1/cases",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"alertId\": \"{{alertId}}\",\n  \"customerId\": \"{{customerId}}\",\n  \"riskScore\": 92\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('201 Created', () => pm.response.to.have.status(201));",
              "pm.collectionVariables.set('caseId', pm.response.json().id);"
            ], "type": "text/javascript" }
          }]
        },
        {
          "name": "E2E 5 – Score Incident via ML Engine",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{ml_url}}/v1/incidents/score",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"features\": [{\n    \"windowId\": \"win-e2e-001\",\n    \"service\": \"transaction-monitoring\",\n    \"windowStart\": \"2026-05-12T02:00:00Z\",\n    \"windowEnd\":   \"2026-05-12T02:05:00Z\",\n    \"avgValue\": 1100.0,\n    \"maxValue\": 2400.0,\n    \"rateOfChange\": 5.8,\n    \"metricName\": \"http_request_duration_ms_p95\",\n    \"sampleCount\": 300\n  }]\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('200 OK', () => pm.response.to.have.status(200));",
              "const inc = pm.response.json()[0];",
              "pm.collectionVariables.set('incidentId', inc.incidentId);"
            ], "type": "text/javascript" }
          }]
        },
        {
          "name": "E2E 6 – Analyze via LLM Engine",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{llm_url}}/v1/analyze",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"incidentId\":       \"{{incidentId}}\",\n  \"service\":          \"transaction-monitoring\",\n  \"anomalyScore\":     0.95,\n  \"rootCause\":        \"extreme latency — CN→KP high-value wire triggered rule cascade\",\n  \"breachEtaMinutes\": 5,\n  \"confidence\":       0.91\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('200 OK', () => pm.response.to.have.status(200));",

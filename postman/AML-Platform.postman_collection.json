    {
      "name": "Transaction Monitoring",
      "item": [
        {
          "name": "Evaluate Transaction – Low Risk",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{txn_url}}/api/v1/transactions/evaluate",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerId\": \"{{customerId}}\",\n  \"amount\": \"450.00\",\n  \"currency\": \"USD\",\n  \"originCountry\": \"US\",\n  \"destinationCountry\": \"US\",\n  \"channel\": \"CARD\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('200 or 201', () => pm.expect(pm.response.code).to.be.oneOf([200, 201]));",
              "const b = pm.response.json();",
              "pm.test('transactionId present', () => pm.expect(b.transactionId).to.be.a('string').and.not.empty);",
              "pm.test('riskScore numeric', () => pm.expect(b.riskScore).to.be.a('number'));",
              "pm.test('alerted boolean', () => pm.expect(b.alerted).to.be.a('boolean'));",
              "if (b.alertId) pm.collectionVariables.set('alertId', b.alertId);"
            ], "type": "text/javascript" }
          }]
        },
        {
          "name": "Evaluate Transaction – High Risk Cross-Border",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{txn_url}}/api/v1/transactions/evaluate",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerId\": \"{{customerId}}\",\n  \"amount\": \"95000.00\",\n  \"currency\": \"USD\",\n  \"originCountry\": \"US\",\n  \"destinationCountry\": \"IR\",\n  \"channel\": \"SWIFT\",\n  \"occurredAt\": \"2026-05-12T02:30:00Z\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('200 or 201', () => pm.expect(pm.response.code).to.be.oneOf([200, 201]));",
              "const b = pm.response.json();",
              "pm.test('transactionId present', () => pm.expect(b.transactionId).to.be.a('string').and.not.empty);",
              "pm.test('riskScore numeric', () => pm.expect(b.riskScore).to.be.a('number'));",
              "if (b.alertId) {",
              "  pm.collectionVariables.set('alertId', b.alertId);",
              "  pm.test('alerted true', () => pm.expect(b.alerted).to.be.true);",
              "}"
            ], "type": "text/javascript" }
          }]
        },
        {
          "name": "Evaluate Transaction – Missing Field (400)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
